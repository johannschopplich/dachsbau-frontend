{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{css,html,json,md,mjs,ts,vue,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,md,mjs,ts,vue,yml}\" --check",
    "test:types": "vue-tsc -b --noEmit",
    "prepare": "nuxt prepare"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@sindresorhus/slugify": "^3.0.0",
    "@types/node": "^24.12.0",
    "@unocss/eslint-config": "^66.6.7",
    "@unocss/nuxt": "^66.6.7",
    "@vueuse/nuxt": "^14.2.1",
    "culori": "^4.0.2",
    "eslint": "^10.0.3",
    "kirby-types": "^1.4.7",
    "nuxt": "^4.4.2",
    "nuxt-kirby": "^3.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.7",
    "vue-router-better-scroller": "^0.0.0",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
